# OpenRouter Configuration
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Environment
ENVIRONMENT=production
TIMEZONE=Asia/Calcutta

# Cost Optimization
COST_OPTIMIZATION_ENABLED=true
DEFAULT_MODEL=openrouter/auto
FALLBACK_MODEL=openrouter/google/gemini-2.5-flash-lite

# Session Management
MAX_CONTEXT_SIZE=50k
AUTO_COMPACT_THRESHOLD=40k
SESSION_LIGHT_CONTEXT_MODE=true

# Heartbeat Settings
HEARTBEAT_ENABLED=true
HEARTBEAT_MODEL=openrouter/google/gemini-2.5-flash-lite
HEARTBEAT_SCHEDULE_MORNING=09:00
HEARTBEAT_SCHEDULE_EVENING=18:00
HEARTBEAT_SILENT_HOURS_START=21:00
HEARTBEAT_SILENT_HOURS_END=09:00

# QMD Search
QMD_ENABLED=true
QMD_MAX_RESULTS=10

# Logging
LOG_LEVEL=info
LOG_FILE=logs/openclaw.log
