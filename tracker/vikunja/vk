#!/bin/bash
# vk - Vikunja CLI helper for AICloudStrategist tracker
#
# Usage:
#   vk projects                          - list all projects with IDs
#   vk tree                              - project tree with task counts
#   vk tasks <project_id>                - list tasks in a project (incl labels)
#   vk all                               - list every task across every project
#   vk task <task_id>                    - show one task as JSON
#   vk add <project_id> "title" [desc]   - create a task
#   vk done <task_id>                    - mark task done
#   vk reopen <task_id>                  - mark task undone
#   vk label <task_id> <label_name>      - attach label to task
#   vk unlabel <task_id> <label_name>    - detach label from task
#   vk prio <task_id> <1-5>              - priority (5=do now, 1=low)
#   vk due <task_id> <YYYY-MM-DD>        - set due date
#   vk create-project <title> [desc]     - create new project
#   vk labels                            - list all labels
#   vk create-label <name> [hex_color]   - create a label
#   vk search "<query>"                  - search tasks by title
#
# Token read from /docker/vikunja/.admin-creds.
# End of help block.

set -euo pipefail

API="https://tracker.srv1562252.hstgr.cloud/api/v1"
TOKEN=$(grep '^api_token:' /docker/vikunja/.admin-creds | awk '{print $2}')
if [ -z "$TOKEN" ]; then
    echo "ERROR: no api_token in /docker/vikunja/.admin-creds" >&2
    exit 1
fi

H_AUTH="Authorization: Bearer ${TOKEN}"
H_JSON="Content-Type: application/json"

py() { python3 -c "$1"; }

# Call a JSON API; exit non-zero if response has an error code
api_call() {
    local method="$1"
    local path="$2"
    local body="${3:-}"
    local tmp
    tmp=$(mktemp)
    local http_code
    if [ -z "$body" ]; then
        http_code=$(curl -sS -o "$tmp" -w "%{http_code}" -X "$method" -H "$H_AUTH" "$API$path")
    else
        http_code=$(curl -sS -o "$tmp" -w "%{http_code}" -X "$method" -H "$H_AUTH" -H "$H_JSON" -d "$body" "$API$path")
    fi
    if [ "$http_code" -ge 400 ]; then
        echo "ERROR: $method $path -> HTTP $http_code" >&2
        cat "$tmp" >&2
        echo "" >&2
        rm -f "$tmp"
        exit 1
    fi
    cat "$tmp"
    rm -f "$tmp"
}

# Cache of project_id -> table_view_id (for label-populated listing)
VIEWS_CACHE="/tmp/vk-views-cache.json"
get_table_view_id() {
    local pid="$1"
    # Refresh cache if older than 5 min
    if [ ! -f "$VIEWS_CACHE" ] || [ "$(find "$VIEWS_CACHE" -mmin +5 2>/dev/null)" ]; then
        local map="{}"
        local projects
        projects=$(api_call GET "/projects")
        map=$(echo "$projects" | TOKEN="$TOKEN" API="$API" py '
import os, sys, json, urllib.request
projects = json.load(sys.stdin) or []
out = {}
for p in projects:
    pid = str(p.get("id"))
    req = urllib.request.Request(os.environ["API"] + "/projects/" + pid + "/views",
                                 headers={"Authorization": "Bearer " + os.environ["TOKEN"]})
    try:
        views = json.loads(urllib.request.urlopen(req, timeout=10).read()) or []
    except Exception:
        continue
    for v in views:
        if v.get("view_kind") == "table":
            out[pid] = v.get("id")
            break
print(json.dumps(out))
')
        echo "$map" > "$VIEWS_CACHE"
    fi
    py "
import json, sys
cache = json.load(open('$VIEWS_CACHE'))
print(cache.get('$pid', ''))
"
}

cmd="${1:-}"
shift || true

case "$cmd" in
projects)
    api_call GET "/projects" | py '
import sys, json
for p in json.load(sys.stdin) or []:
    pid = p.get("id")
    title = p.get("title", "")
    arch = "(archived)" if p.get("is_archived") else ""
    line = "%4d  %s %s" % (pid, title, arch)
    print(line.rstrip())
'
    ;;

tree)
    api_call GET "/projects" | TOKEN="$TOKEN" API="$API" py '
import os, sys, json, urllib.request
API = os.environ["API"]
TOKEN = os.environ["TOKEN"]
for p in json.load(sys.stdin) or []:
    pid = p.get("id")
    title = p.get("title", "")
    arch = "(archived)" if p.get("is_archived") else ""
    req = urllib.request.Request(API + "/projects/" + str(pid) + "/tasks", headers={"Authorization": "Bearer " + TOKEN})
    try:
        tasks = json.loads(urllib.request.urlopen(req, timeout=10).read()) or []
    except Exception:
        tasks = []
    open_n = sum(1 for t in tasks if not t.get("done"))
    done_n = sum(1 for t in tasks if t.get("done"))
    print("%4d  %s %s - open: %d, done: %d" % (pid, title, arch, open_n, done_n))
'
    ;;

tasks)
    pid="${1:-}"
    if [ -z "$pid" ]; then echo "usage: vk tasks <project_id>"; exit 1; fi
    view_id=$(get_table_view_id "$pid")
    if [ -z "$view_id" ]; then
        echo "ERROR: no table view found for project $pid" >&2
        exit 1
    fi
    api_call GET "/projects/$pid/views/$view_id/tasks" | py '
import sys, json
tasks = json.load(sys.stdin) or []
if not tasks:
    print("(no tasks)")
    sys.exit(0)
tasks.sort(key=lambda t: (t.get("done", False), -(t.get("priority") or 0), t.get("id")))
for t in tasks:
    tid = t.get("id")
    mark = "[x]" if t.get("done") else "[ ]"
    title = t.get("title", "")
    prio = t.get("priority") or 0
    due = t.get("due_date", "") or ""
    due_s = " due:" + due[:10] if due and not due.startswith("0001-01-01") else ""
    prio_s = " p%d" % prio if prio else ""
    labels = t.get("labels") or []
    lab_s = ""
    if labels:
        lab_s = " [" + ", ".join(l.get("title", "") for l in labels) + "]"
    print("%5d  %s %s%s%s%s" % (tid, mark, title, prio_s, due_s, lab_s))
'
    ;;

all)
    # Iterate every project and print labeled tasks
    api_call GET "/projects" | TOKEN="$TOKEN" API="$API" py '
import os, sys, json, urllib.request
API = os.environ["API"]
TOKEN = os.environ["TOKEN"]
projects = json.load(sys.stdin) or []
for p in projects:
    pid = p.get("id")
    if p.get("is_archived"):
        continue
    # Find table view
    vreq = urllib.request.Request(API + "/projects/" + str(pid) + "/views", headers={"Authorization": "Bearer " + TOKEN})
    views = []
    try:
        views = json.loads(urllib.request.urlopen(vreq, timeout=10).read()) or []
    except Exception:
        continue
    view_id = None
    for v in views:
        if v.get("view_kind") == "table":
            view_id = v.get("id")
            break
    if not view_id:
        continue
    treq = urllib.request.Request(API + "/projects/" + str(pid) + "/views/" + str(view_id) + "/tasks", headers={"Authorization": "Bearer " + TOKEN})
    try:
        tasks = json.loads(urllib.request.urlopen(treq, timeout=10).read()) or []
    except Exception:
        continue
    if not tasks:
        continue
    tasks.sort(key=lambda t: (t.get("done", False), -(t.get("priority") or 0), t.get("id")))
    print("\n== %s (id=%d) ==" % (p.get("title", ""), pid))
    for t in tasks:
        mark = "[x]" if t.get("done") else "[ ]"
        prio = t.get("priority") or 0
        due = t.get("due_date", "") or ""
        due_s = " due:" + due[:10] if due and not due.startswith("0001-01-01") else ""
        prio_s = " p%d" % prio if prio else ""
        labels = t.get("labels") or []
        lab_s = " [" + ", ".join(l.get("title", "") for l in labels) + "]" if labels else ""
        print("%5d  %s %s%s%s%s" % (t.get("id"), mark, t.get("title", ""), prio_s, due_s, lab_s))
'
    ;;

task)
    tid="${1:-}"
    if [ -z "$tid" ]; then echo "usage: vk task <task_id>"; exit 1; fi
    api_call GET "/tasks/$tid" | python3 -m json.tool
    ;;

add)
    pid="${1:-}"
    title="${2:-}"
    desc="${3:-}"
    if [ -z "$pid" ] || [ -z "$title" ]; then
        echo 'usage: vk add <project_id> "title" [description]'; exit 1
    fi
    body=$(TITLE="$title" DESC="$desc" py '
import os, json
print(json.dumps({"title": os.environ["TITLE"], "description": os.environ.get("DESC", "")}))
')
    api_call PUT "/projects/$pid/tasks" "$body" | py '
import sys, json
t = json.load(sys.stdin)
print("created task " + str(t.get("id")) + ": " + str(t.get("title", "")))
'
    ;;

done)
    tid="${1:-}"
    if [ -z "$tid" ]; then echo "usage: vk done <task_id>"; exit 1; fi
    api_call POST "/tasks/$tid" '{"done":true}' | py '
import sys, json
t = json.load(sys.stdin)
print("done: [" + str(t.get("id")) + "] " + str(t.get("title", "")))
'
    ;;

reopen)
    tid="${1:-}"
    if [ -z "$tid" ]; then echo "usage: vk reopen <task_id>"; exit 1; fi
    api_call POST "/tasks/$tid" '{"done":false}' | py '
import sys, json
t = json.load(sys.stdin)
print("reopened: [" + str(t.get("id")) + "] " + str(t.get("title", "")))
'
    ;;

prio)
    tid="${1:-}"
    p="${2:-}"
    if [ -z "$tid" ] || [ -z "$p" ]; then echo "usage: vk prio <task_id> <1-5>"; exit 1; fi
    api_call POST "/tasks/$tid" "{\"priority\":$p}" >/dev/null
    echo "priority set to $p"
    ;;

due)
    tid="${1:-}"
    d="${2:-}"
    if [ -z "$tid" ] || [ -z "$d" ]; then echo "usage: vk due <task_id> <YYYY-MM-DD>"; exit 1; fi
    api_call POST "/tasks/$tid" "{\"due_date\":\"${d}T00:00:00Z\"}" >/dev/null
    echo "due date set to $d"
    ;;

label)
    tid="${1:-}"
    lname="${2:-}"
    if [ -z "$tid" ] || [ -z "$lname" ]; then echo "usage: vk label <task_id> <label_name>"; exit 1; fi
    # Find label id; create if missing
    lid=$(api_call GET "/labels" | LNAME="$lname" py '
import os, sys, json
name = os.environ["LNAME"].lower()
for l in json.load(sys.stdin) or []:
    if l.get("title", "").lower() == name:
        print(l.get("id"))
        break
')
    if [ -z "$lid" ]; then
        body=$(LNAME="$lname" py '
import os, json
print(json.dumps({"title": os.environ["LNAME"]}))
')
        lid=$(api_call PUT "/labels" "$body" | py '
import sys, json
print(json.load(sys.stdin).get("id"))
')
        echo "created label '$lname' id=$lid"
    fi
    api_call PUT "/tasks/$tid/labels" "{\"label_id\":$lid}" >/dev/null
    echo "labeled task $tid with '$lname'"
    ;;

unlabel)
    tid="${1:-}"
    lname="${2:-}"
    if [ -z "$tid" ] || [ -z "$lname" ]; then echo "usage: vk unlabel <task_id> <label_name>"; exit 1; fi
    lid=$(api_call GET "/labels" | LNAME="$lname" py '
import os, sys, json
name = os.environ["LNAME"].lower()
for l in json.load(sys.stdin) or []:
    if l.get("title", "").lower() == name:
        print(l.get("id"))
        break
')
    if [ -z "$lid" ]; then echo "no label '$lname'"; exit 1; fi
    api_call DELETE "/tasks/$tid/labels/$lid" >/dev/null
    echo "removed label '$lname' from task $tid"
    ;;

create-project)
    title="${1:-}"
    desc="${2:-}"
    if [ -z "$title" ]; then echo "usage: vk create-project <title> [desc]"; exit 1; fi
    body=$(TITLE="$title" DESC="$desc" py '
import os, json
print(json.dumps({"title": os.environ["TITLE"], "description": os.environ.get("DESC", "")}))
')
    api_call PUT "/projects" "$body" | py '
import sys, json
p = json.load(sys.stdin)
print("created project " + str(p.get("id")) + ": " + str(p.get("title", "")))
'
    ;;

labels)
    api_call GET "/labels" | py '
import sys, json
for l in json.load(sys.stdin) or []:
    color = l.get("hex_color") or "-"
    print("%4d  %s  (%s)" % (l.get("id"), l.get("title", ""), color))
'
    ;;

create-label)
    name="${1:-}"
    color="${2:-}"
    if [ -z "$name" ]; then echo "usage: vk create-label <name> [hex_color]"; exit 1; fi
    body=$(NAME="$name" COLOR="$color" py '
import os, json
d = {"title": os.environ["NAME"]}
if os.environ.get("COLOR"):
    d["hex_color"] = os.environ["COLOR"]
print(json.dumps(d))
')
    api_call PUT "/labels" "$body" | py '
import sys, json
l = json.load(sys.stdin)
print("created label " + str(l.get("id")) + ": " + str(l.get("title", "")))
'
    ;;

search)
    q="${1:-}"
    if [ -z "$q" ]; then echo 'usage: vk search "<query>"'; exit 1; fi
    # tasks_all is gated; iterate via project tasks endpoints instead
    api_call GET "/projects" | TOKEN="$TOKEN" API="$API" Q="$q" py '
import os, sys, json, urllib.request
API = os.environ["API"]
TOKEN = os.environ["TOKEN"]
q = os.environ["Q"].lower()
for p in json.load(sys.stdin) or []:
    pid = p.get("id")
    if p.get("is_archived"):
        continue
    req = urllib.request.Request(API + "/projects/" + str(pid) + "/tasks", headers={"Authorization": "Bearer " + TOKEN})
    try:
        tasks = json.loads(urllib.request.urlopen(req, timeout=10).read()) or []
    except Exception:
        continue
    for t in tasks:
        title = t.get("title", "")
        if q in title.lower():
            mark = "[x]" if t.get("done") else "[ ]"
            print("%5d  %s %s  (project %d)" % (t.get("id"), mark, title, pid))
'
    ;;

""|help|-h|--help)
    # Print help block: every leading-# line from top of script until 'End of help block.'
    py '
import sys, re
lines = open("'"$0"'").read().splitlines()
for ln in lines[1:]:  # skip shebang
    if ln.startswith("# End of help block."):
        break
    if ln.startswith("#"):
        print(re.sub(r"^# ?", "", ln))
    elif ln.strip() == "":
        print("")
'
    ;;

*)
    echo "unknown command: $cmd" >&2
    echo "try: vk help" >&2
    exit 1
    ;;
esac
